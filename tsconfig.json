{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve"
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "src/AuditExpress/components/NavbarLargeScreen.jsx",
    "src/AuditExpress/components/Navbar.jsx",
    "src/Auditexpress/ScanIdPage.tsx"
  ],
  "exclude": ["node_modules"]
}
